{
  "name": "tailwint",
  "version": "1.1.6",
  "description": "Tailwind CSS linter for CI — drives the official language server to catch class issues and auto-fix them",
  "license": "MIT",
  "author": "Peter Wang",
  "homepage": "https://github.com/peterwangsc/tailwint",
  "bugs": "https://github.com/peterwangsc/tailwint/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peterwangsc/tailwint.git"
  },
  "keywords": [
    "tailwindcss",
    "tailwind",
    "lint",
    "linter",
    "ci",
    "autofix",
    "language-server",
    "lsp",
    "tailwind-v4",
    "css",
    "diagnostics",
    "code-quality"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "tailwint": "bin/tailwint.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "rm -rf dist && tsc",
    "test": "tsx --test tests/*.test.ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "glob": "^13.0.6"
  },
  "peerDependencies": {
    "@tailwindcss/language-server": ">=0.14.0"
  },
  "devDependencies": {
    "@tailwindcss/language-server": "^0.14.29",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
