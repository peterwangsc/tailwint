{
  "name": "tailwint",
  "version": "1.1.13",
  "description": "Tiny Tailwind CSS linter and auto-fixer for CI — powered by the official language server, not regex",
  "license": "MIT",
  "author": "Peter Wang",
  "homepage": "https://github.com/peterwangsc/tailwint",
  "bugs": "https://github.com/peterwangsc/tailwint/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peterwangsc/tailwint.git"
  },
  "keywords": [
    "tailwindcss",
    "tailwind",
    "tailwind-lint",
    "lint",
    "linter",
    "cli",
    "ci",
    "ci-cd",
    "autofix",
    "language-server",
    "lsp",
    "tailwind-v4",
    "css",
    "diagnostics",
    "code-quality",
    "class-conflicts",
    "canonical",
    "github-actions",
    "pre-commit",
    "static-analysis"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "tailwint": "bin/tailwint.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "rm -rf dist && esbuild src/index.ts src/edits.ts src/lsp.ts src/prescan.ts src/ui.ts --outdir=dist --format=esm --platform=node --target=node18 --minify && tsc --emitDeclarationOnly",
    "test": "tsx --test tests/*.test.ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "glob": "^13.0.6"
  },
  "peerDependencies": {
    "@tailwindcss/language-server": ">=0.14.0"
  },
  "devDependencies": {
    "@tailwindcss/language-server": "^0.14.29",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
